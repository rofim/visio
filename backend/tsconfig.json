{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@common": ["../libs/common/src"],
      "@common/*": ["../libs/common/src/*"],
      "@common-test": ["../libs/common/test"],
      "@common-test/*": ["../libs/common/test/*"]
    }
  }
}
