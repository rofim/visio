{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "backend",
  "projectType": "application",
  "root": "backend",
  "sourceRoot": "backend",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "nodemon --watch . --ext ts,tsx,json --ignore dist --exec \"sh -c 'tsc --noEmit -p tsconfig.json --pretty true && node --import tsx index.ts'\""
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "node ./dist/bundle.cjs"
      },
      "dependsOn": ["build"]
    },
    "start:bundled": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "node ./dist/bundle.cjs"
      },
      "dependsOn": ["build:dev"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "webpack --config ../backend/webpack.config.cjs --target node --mode production"
      },
      "outputs": ["{workspaceRoot}/backend/dist"]
    },
    "build:dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "webpack --config ../backend/webpack.config.cjs --target node --mode development"
      },
      "outputs": ["{workspaceRoot}/backend/dist"]
    },
    "debug": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "nodemon --watch . --ext ts,tsx,json --ignore dist --exec \"sh -c 'tsc --noEmit -p tsconfig.json --pretty true && node --inspect --import tsx index.ts'\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "bash -c 'source ../vcrBuild.env.sh && NODE_OPTIONS=\"--experimental-vm-modules\" jest --maxWorkers=1'"
      },
      "inputs": ["default", "^default", { "externalDependencies": ["jest", "ts-jest"] }],
      "configurations": {
        "coverage": {
          "command": "bash -c 'source ../vcrBuild.env.sh && NODE_OPTIONS=\"--experimental-vm-modules\" jest --maxWorkers=1 --coverage'"
        }
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "eslint '**/*.ts' --report-unused-disable-directives --max-warnings 0"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "eslint '**/*.ts' --fix --report-unused-disable-directives --max-warnings 0"
      }
    },
    "ts-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "tsc --noEmit -p tsconfig.json --pretty true"
      }
    }
  },
  "tags": []
}
