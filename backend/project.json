{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "backend",
  "projectType": "application",
  "root": "backend",
  "sourceRoot": "backend",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "nodemon --watch . --ext ts,tsx,json --ignore dist --exec \"sh -c 'tsc --noEmit -p tsconfig.json --pretty true && node --import tsx index.ts'\""
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "node bundle.cjs"
      },
      "dependsOn": ["build"]
    },

    "start:development": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "node bundle.cjs"
      },
      "dependsOn": ["build:development"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "webpack --config backend/webpack.config.cjs --target node --mode production"
      },
      "outputs": ["{workspaceRoot}/backend/dist"]
    },
    "build:development": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "webpack --config backend/webpack.config.cjs --target node --mode development"
      },
      "outputs": ["{workspaceRoot}/backend/dist"]
    },
    "debug": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "nodemon --watch . --ext ts,tsx,json --ignore dist --exec \"sh -c 'tsc --noEmit -p tsconfig.json --pretty true && node --inspect --import tsx index.ts'\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --maxWorkers=1 --coverage"
      },
      "configurations": {
        "watch": {
          "command": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --maxWorkers=1 --coverage --watch"
        }
      },
      "inputs": ["default", "^default", { "externalDependencies": ["jest", "ts-jest"] }]
    },
    "test:debug": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "NODE_OPTIONS=\"--experimental-vm-modules --inspect-brk\" jest --runInBand --detectOpenHandles --verbose"
      },
      "inputs": ["default", "^default", { "externalDependencies": ["jest", "ts-jest"] }]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "eslint . --report-unused-disable-directives --max-warnings 0"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "eslint . --fix --report-unused-disable-directives --max-warnings 0"
      }
    },
    "ts-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "backend",
        "command": "tsc --noEmit -p tsconfig.json --pretty true"
      }
    }
  },
  "tags": []
}
