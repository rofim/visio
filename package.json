{
  "name": "vonage-video-react-app",
  "version": "1.3.1",
  "description": "React reference application for the Vonage Video web client SDK.",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "integration-tests"
  ],
  "engines": {
    "node": ">=22.x",
    "npm": "9.x"
  },
  "scripts": {
    "quality-check": "yarn --silent ts-check && yarn --silent lint:fix",
    "build": "yarn workspace frontend build",
    "deploy-vcr": "vcr deploy",
    "dev:frontend": "yarn workspace frontend dev",
    "dev:backend": "yarn workspace backend dev",
    "dev": "yarn && concurrently 'yarn dev:frontend' 'yarn dev:backend'",
    "docs": "yarn workspace frontend docs",
    "docs:watch": "yarn workspace frontend docs:watch",
    "lint": "ESLINT_USE_FLAT_CONFIG=false yarn eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:filenames": "./scripts/lintFileNames.sh",
    "lint:fix": "prettier --log-level warn --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\" && yarn lint --fix",
    "prepare": "husky install",
    "run-server": "yarn workspace backend start",
    "start": "yarn workspace frontend build && yarn workspace backend start",
    "start:backend": "yarn workspace backend dev",
    "debug:backend": "yarn workspace backend debug",
    "start:frontend": "yarn workspace frontend dev",
    "test": "yarn test:backend && yarn test:frontend",
    "test:backend": "yarn workspace backend test",
    "test:backend:watch": "yarn workspace backend test:watch",
    "test:frontend": "yarn workspace frontend test",
    "test:frontend:": "yarn test:frontend -- --bail 1 --no-coverage",
    "test:frontend:debug": "vitest --disableConsoleIntercept=true --silent=false --no-file-parallelism --inspect-brk --root frontend --config vite.config.ts --no-coverage",
    "test:frontend:watch": "yarn workspace frontend test:watch",
    "test:integration": "yarn workspace integration-tests test",
    "ts-check": "yarn --silent ts-check:backend && yarn --silent ts-check:frontend",
    "test:integrationUpdateScreenshots": "yarn workspace integration-tests updateScreenshots",
    "ts-check:backend": "yarn --silent workspace backend ts-check",
    "ts-check:frontend": "yarn --silent workspace frontend ts-check",
    "vite-plugin-checker": "^0.11.0"
  },
  "scriptsInfo": {
    "dev": "Run both frontend and backend in development mode which included compilation type checking and hot reloading",
    "debug:backend": "Run backend in debug mode which allows you to attach a debugger or debug directly with chrome://inspect",
    "test:frontend": "Run frontend tests",
    "test:frontend:": "example: 'yarn test:frontend: <name/path>' to run specific test file or test suite without coverage",
    "test:frontend:debug": "Debug mode which allows you to attach a debugger or debug directly with chrome://inspect"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vonage/vonage-video-react-app.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Vonage/vonage-video-react-app/issues"
  },
  "homepage": "https://github.com/Vonage/vonage-video-react-app#readme",
  "devDependencies": {
    "@cspell/eslint-plugin": "^8.14.4",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-filename-rules": "^1.3.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.8.3",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.1",
    "eslint-plugin-react-refresh": "^0.4.6",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "husky": "^9.0.11",
    "license-checker": "^25.0.1",
    "prettier": "^3.2.5",
    "typescript": "^5.8.3"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "path-to-regexp": "^0.1.12",
    "express": "^4.21.2",
    "axios": "^1.12.0",
    "cross-spawn": "^7.0.5",
    "rollup": "^4.22.4",
    "vite": "^5.4.19",
    "nanoid": "^3.3.8",
    "micromatch": "^4.0.8",
    "@babel/helpers": "^7.27.0",
    "@babel/runtime": "^7.26.10",
    "brace-expansion": "2.0.2",
    "form-data": "^4.0.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
