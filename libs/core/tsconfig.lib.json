{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vite/client"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../common/src/**/*.ts",
    "../common/src/**/*.tsx",
    "../common/srcBrowser/**/*.ts",
    "../common/srcBrowser/**/*.tsx",
    "../common/test/**/*.ts",
    "../common/test/**/*.tsx",
    "../common/testBrowser/**/*.ts",
    "../common/testBrowser/**/*.tsx",

    // video-router(this is just for linter and types)
    "../api/src/**/*.ts",
    "../common/srcNode/**/*.ts",
    "../common/src/types/FacingMode.ts"
  ],
  "exclude": [
    "**/*.spec.*",
    "**/*.test.*",
    "../api/**/*.test.*",
    "../api/**/*.spec.*",
    "../common/**/*.test.*",
    "../common/**/*.spec.*"
  ]
}
