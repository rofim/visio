{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "vite.config.ts",
    "test/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "../common/src/**/*.ts",
    "../common/src/**/*.tsx"
  ],
  "tsBuildInfoFile": "dist/tsconfig.spec.tsbuildinfo"
}
