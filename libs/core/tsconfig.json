{
  "extends": "../../tsconfig.base.json",
  "files": [],
  "include": ["eslint.config.mjs", "./test/setup.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ],
  "compilerOptions": {
    "rootDir": "..",
    "baseUrl": "./",
    "moduleResolution": "bundler",
    "composite": true,
    "paths": {
      "@common": ["../common/src"],
      "@common/*": ["../common/src/*"],
      "@core": ["./src"],
      "@core/*": ["./src/*"],
      "@common-test": ["../common/test"],
      "@common-test/*": ["../common/test/*"]
    },
    "lib": ["DOM", "DOM.Iterable", "ESNext"]
  }
}
