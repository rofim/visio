{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "src/theme/helpers/tailwind/index.cjs",
    "../common/src/**/*.ts",
    "../common/src/**/*.tsx",
    "../common/srcBrowser/**/*.ts",
    "../common/srcBrowser/**/*.tsx",
    "../common/test/**/*.ts",
    "../common/test/**/*.tsx",
    "../common/testBrowser/**/*.ts",
    "../common/testBrowser/**/*.tsx",
    "../core/src/**/*.ts",
    "../core/src/**/*.tsx"
  ],
  "exclude": ["**/*.spec.*", "**/*.test.*"]
}
