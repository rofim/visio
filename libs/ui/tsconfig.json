{
  "extends": "../../tsconfig.base.json",
  "files": [],
  "include": ["eslint.config.mjs"],
  "references": [{ "path": "./tsconfig.lib.json" }, { "path": "./tsconfig.spec.json" }],
  "compilerOptions": {
    "rootDir": "..",
    "composite": true,
    "baseUrl": "./",
    "moduleResolution": "node",
    "paths": {
      "@ui/*": ["./src/*"],
      "@ui": ["./src"],
      "@common-test/*": ["../common/test/*"],
      "@common-test": ["../common/test"],
      "@core/*": ["../core/src/*"],
      "@core": ["../core/src"],
      "@common/*": ["../common/src/*"],
      "@common": ["../common/src"]
    },
    "lib": ["DOM", "DOM.Iterable", "ESNext"]
  }
}
