{
  "extends": "../../tsconfig.base.json",
  "files": [],
  "include": ["eslint.config.mjs", "vite.config.ts", "./test/setup.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ],
  "compilerOptions": {
    "rootDir": "..",
    "baseUrl": "./",
    "moduleResolution": "node",
    "composite": true,
    "paths": {
      "@api-lib": ["./src"],
      "@api-lib/*": ["./src/*"],
      "@common": ["../common/src"],
      "@common/*": ["../common/src/*"],
      "@node": ["../common/srcNode"],
      "@node/*": ["../common/srcNode/*"]
    },
    "lib": ["ESNext"]
  }
}
