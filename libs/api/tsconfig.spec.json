{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vitest/globals", "vitest/importMeta", "node"],
    "tsBuildInfoFile": "dist/tsconfig.spec.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "test/**/*.ts",
    "src/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "../common/src/**/*.ts",
    "../common/srcNode/**/*.ts",
    "../common/test/**/*.ts",
    "../common/testNode/**/*.ts",
    "../common/src/types/FacingMode.ts"
  ]
}
