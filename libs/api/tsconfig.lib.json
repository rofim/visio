{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../common/src/**/*.ts",
    "../common/srcNode/**/*.ts",
    "../common/test/**/*.ts",
    "../common/testNode/**/*.ts",
    "../common/src/types/FacingMode.ts"
  ],
  "exclude": ["**/*.spec.*", "**/*.test.*", "../common/**/*.spec.*", "../common/**/*.test.*"]
}
