{
  "extends": ["./tsconfig.json"],
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "../common/src/**/*.ts"],
  "exclude": ["**/*.spec.*", "**/*.test.*"]
}
